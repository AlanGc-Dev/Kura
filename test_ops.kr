let x = 10;
let y = 3;
print x + y;  // 13
print x - y;  // 7
print x * y;  // 30
print x / y;  // 3
print x % y;  // 1
print x ** y; // 1000
print x == y; // false
print x != y; // true
print x < y;  // false
print x > y;  // true
print x <= y; // false
print x >= y; // true
let s1 = "hola";
let s2 = "mundo";
print s1 == s2; // false
print s1 != s2; // true
print s1 + s2;  // "holamundo"