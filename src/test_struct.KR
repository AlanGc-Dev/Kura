struct Jugador {
    vida: Entero,

    // Nuestro primer Método!
    fn recibir_dano(cantidad) {
        this.vida = this.vida - cantidad;
    }

    // Método con retorno booleano
    fn esta_vivo() {
        return this.vida > 0;
    }
}

// 1. Instanciar el objeto
let heroe = Jugador { vida: 100 };

print "Vida antes del ataque:";
print heroe.vida;

// 2. Llamar a un método para modificar el estado interno
heroe.recibir_dano(60);

print "Vida despues del ataque:";
print heroe.vida;

// 3. Evaluar método en un If
if heroe.esta_vivo() {
    print "El heroe sigue en pie!";
} else {
    print "Game Over";
}