let error = 404;
let exito = 200;

let estado_red = 404;

print "Evaluando el servidor...";

match estado_red {
    exito => {
        print "Todo salio perfecto!";
    },
    error => {
        print "Error encontrado: Archivo no existe";
    },
    _ => {
        print "Codigo desconocido";
    }
}

print "---";

// Prueba 2: Atrapando un valor desconocido (Binding)
match 999 {
    valor_extra => {
        print "El valor atrapado en el switch es:";
        print valor_extra;
    }
}