// ===== ejemplo_modulo.kr (Sistema de Módulos v0.1) =====
// Este es un módulo que exporta funciones

fn saludar(nombre) {
    print "Hola, ";
    print nombre;
    print "!";
}

fn suma(a, b) {
    return a + b;
}

fn multiplicar(x, y) {
    return x * y;
}

// Marcar estos como exports (al final del módulo)
export saludar;
export suma;
export multiplicar;
