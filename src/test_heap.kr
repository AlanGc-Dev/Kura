struct NodoAST {
    tipo: int,
    valor: int
}

print 11111; // Marcador de inicio

// 1. Probando 'new' (Asignación en el Heap / malloc)
let mut mi_nodo = new NodoAST;

// 2. Mutando la memoria asignada
mi_nodo.tipo = 5;
mi_nodo.valor = 1024;

print mi_nodo.tipo;
print mi_nodo.valor;

// 3. Probando 'delete' (Liberación de memoria / free)
delete mi_nodo;

// 4. Probando 'null'
let puntero_vacio = null;

print 99999; // Si llegamos aquí sin que explote, ¡funciona perfecto!