// Definir un enum Result
enum Result {
    Ok(valor),
    Err(mensaje)
}

// Crear instancias de enum
let resultado1 = Ok(42);
let resultado2 = Err("fallo");

// Pattern matching con destructuring
match resultado1 {
    Ok(v) => {
        print "Éxito con valor:";
        print v;
    },
    Err(e) => {
        print "Error:";
        print e;
    }
}

// Segundo test
match resultado2 {
    Ok(v) => {
        print "Éxito con valor:";
        print v;
    },
    Err(e) => {
        print "Error:";
        print e;
    }
}

// Test con comodín
match resultado1 {
    Ok(_) => print "¡Resultado exitoso!",
    Err(_) => print "Resultado fallido"
}
