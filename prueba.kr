struct Personaje {
    nombre: Cadena,
    poder: Entero,

    fn atacar(self, dano) {
        print self.nombre + " ataca con fuerza de:";
        print dano * self.poder;
    }

    fn entrenar(self) {
        self.poder = self.poder + 5;
        print self.nombre + " entreno y ahora su poder es:";
        print self.poder;
    }
}

let heroe = Personaje {
    nombre: "Goku",
    poder: 10s
};

heroe.atacar(2);
heroe.entrenar();
heroe.atacar(2);