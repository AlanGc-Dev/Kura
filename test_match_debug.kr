enum Result {
    Ok(valor),
    Err(mensaje)
}

print "Antes de match";

let resultado1 = Ok(42);

print "Creada instancia";
print resultado1;

match resultado1 {
    Ok(v) => {
        print "En el Ok";
        print v;
    },
    Err(e) => {
        print "En el Err";
        print e;
    }
}

print "Después del match";
